# qwen2api-rs configuration

# Required for all compatibility API calls.
API_KEY=sk-qwen2api-change-me

# HTTP listen port. Docker uses host networking, so this is the host port too.
PORT=7860

# Persistent data directory. accounts.json, stats.db and media files live here.
DATA_DIR=./data

# Provide Qwen accounts in one of two ways:
# 1. Mount ./data/accounts.json (recommended for many accounts):
#    [{"email":"user@example.com","token":"qwen-localStorage-token","password":"optional"}]
# 2. Or pass the same JSON array directly through env:
# QWEN_ACCOUNTS_JSON=[{"email":"user@example.com","token":"qwen-localStorage-token","password":"optional"}]

# Optional: point to a different account file.
# ACCOUNTS_FILE=/absolute/path/accounts.json

# Optional: outbound proxy for chat.qwen.ai. HTTP_PROXY / HTTPS_PROXY are also honored.
# UPSTREAM_PROXY=http://127.0.0.1:7890

# Optional: default upstream model for unknown OpenAI/Claude/Gemini aliases.
DEFAULT_MODEL=qwen3.7-plus

# Optional: log level: trace, debug, info, warn, error.
LOG_LEVEL=info
